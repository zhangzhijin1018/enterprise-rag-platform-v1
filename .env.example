APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# OpenAI-compatible API (set for real LLM / embeddings / reranker via API if you swap providers)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple

REDIS_URL=redis://localhost:6379/0
VECTOR_STORE_PATH=./data/vector_store
MYSQL_URL=mysql+pymysql://rag:rag@127.0.0.1:3306/enterprise_rag
VECTOR_BACKEND=milvus
MILVUS_URI=./data/milvus/enterprise_rag.db
MILVUS_TOKEN=
MILVUS_DB_NAME=
MILVUS_COLLECTION_NAME=rag_chunks
MILVUS_INDEX_TYPE=AUTOINDEX
MILVUS_METRIC_TYPE=COSINE

LLM_MODEL_NAME=gpt-4o-mini
EMBEDDING_MODEL_NAME=BAAI/bge-m3
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3

BM25_TOP_K=20
DENSE_TOP_K=20
HYBRID_TOP_K=30
RERANK_TOP_N=8
FUSION_STRATEGY=rrf

# Grounding / refusal thresholds (applied to weighted fusion scores only; RRF uses rerank/generate gates)
MIN_RETRIEVAL_SCORE=0.15
MIN_RERANK_SCORE=-5.0
REFUSAL_CONFIDENCE_THRESHOLD=0.35
FAQ_BM25_THRESHOLD=0.85
FAQ_TOP_K=3
ANSWER_CACHE_TTL_SEC=86400
FAQ_SEED_PATH=./data/mock_corpus/faq_seed.csv

# 前端开发（Vite）跨域，生产请改为实际域名
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=enterprise-rag-api

# RAGAS eval (uses same OpenAI settings when running eval)
EVAL_OUTPUT_DIR=./data/eval_reports
