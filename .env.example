APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
ENABLE_FILE_LOGGING=true
LOG_DIR=./logs
APP_LOG_FILENAME=app.log
AUDIT_LOG_FILENAME=audit.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# OpenAI-compatible API（推荐直接填你后面购买的阿里百炼 / Qwen 兼容接口）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple

REDIS_URL=redis://localhost:6379/0
QUERY_UNDERSTANDING_VOCAB_PATH=./data/config/query_understanding_vocab.json
MYSQL_URL=mysql+pymysql://rag:rag@127.0.0.1:3306/enterprise_rag
VECTOR_BACKEND=milvus
RETRIEVAL_EMBEDDING_BACKEND=bgem3
BGEM3_DEVICE=auto
BGEM3_USE_FP16=true
MILVUS_URI=./data/milvus/enterprise_rag.db
MILVUS_TOKEN=
MILVUS_DB_NAME=
MILVUS_COLLECTION_NAME=rag_chunks
MILVUS_INDEX_TYPE=AUTOINDEX
MILVUS_METRIC_TYPE=COSINE

LLM_MODEL_NAME=qwen-plus
QUERY_UNDERSTANDING_MODEL_NAME=qwen-turbo
QUERY_PLANNING_MODEL_NAME=qwen-turbo
ANSWER_GENERATION_MODEL_NAME=qwen-plus
EMBEDDING_MODEL_NAME=./modes/bge-m3
RERANKER_MODEL_NAME=./modes/bge-reranker-large

BM25_TOP_K=20
DENSE_TOP_K=20
HYBRID_TOP_K=30
RERANK_TOP_N=8
RERANK_CANDIDATE_MULTIPLIER=4
RERANK_CANDIDATE_MAX=24
BROAD_SUB_QUERY_LIMIT=3
BALANCED_SUB_QUERY_LIMIT=2
KEYWORD_ROUTE_LIMIT=2
QUERY_UNDERSTANDING_CONFIDENCE_THRESHOLD=0.78
QUERY_UNDERSTANDING_FORCE_HYBRID_THRESHOLD=0.58
QUERY_UNDERSTANDING_MAX_TOKENS=512
METADATA_MATCH_BOOST=0.08
ENTERPRISE_ENTITY_MATCH_BOOST=0.12
STRUCTURED_FILTER_BOOST=0.05
FUSION_STRATEGY=rrf
WEIGHTED_FUSION_QUERY_SCENES=policy_lookup,error_code_lookup,structured_fact_lookup
WEIGHTED_FUSION_SCENE_WEIGHTS=policy_lookup:0.65,error_code_lookup:0.75,structured_fact_lookup:0.70

# Grounding / refusal thresholds (applied to weighted fusion scores only; RRF uses rerank/generate gates)
MIN_RETRIEVAL_SCORE=0.15
MIN_RERANK_SCORE=-5.0
REFUSAL_CONFIDENCE_THRESHOLD=0.35
FAQ_BM25_THRESHOLD=0.85
FAQ_TOP_K=3
ANSWER_CACHE_TTL_SEC=86400
FAQ_SEED_PATH=./data/mock_corpus/faq_seed.csv

# 前端开发（Vite）跨域，生产请改为实际域名
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=enterprise-rag-api

# RAGAS eval (uses same OpenAI settings when running eval)
EVAL_OUTPUT_DIR=./data/eval_reports
